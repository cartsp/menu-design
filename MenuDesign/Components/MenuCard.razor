@inject IJSRuntime JS

<button @ref="_ref"
        class="menu-card liquid-glass rounded-[2rem] md:rounded-[2.5rem] animate-card-in"
        @onclick="HandleClick"
        @onmouseenter="PlayHover">
    <div class="ripple-container"></div>
    <div class="icon-orb w-14 h-14 md:w-20 md:h-20 lg:w-24 lg:h-24
                flex items-center justify-center shadow-lg @OrbAccent">
        <span class="material-symbols-outlined text-white text-3xl md:text-5xl lg:text-6xl @IconExtraCss">
            @Icon
        </span>
    </div>
    <div>
        <h2 class="font-headline text-lg md:text-xl lg:text-2xl text-sky-900 font-bold">@Title</h2>
        <p class="text-sky-800/50 text-[9px] md:text-[10px] lg:text-xs font-semibold uppercase tracking-widest mt-1">@Subtitle</p>
    </div>
</button>

@code {
    private ElementReference _ref;

    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string OrbAccent { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string IconExtraCss { get; set; } = "";
    [Parameter] public bool SoundEnabled { get; set; } = true;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick()
    {
        await AddRipple();
        await OnClick.InvokeAsync();
    }

    private async Task AddRipple()
    {
        try
        {
            await JS.InvokeVoidAsync("addRipple", _ref);
        }
        catch (JSDisconnectedException)
        {
            // Runtime shutting down — expected during navigation/dispose
        }
        catch (JSException ex)
        {
            Console.WriteLine($"[MenuCard] Ripple error: {ex.Message}");
        }
    }

    private async Task PlayHover()
    {
        if (!SoundEnabled) return;
        try
        {
            await JS.InvokeVoidAsync("playHoverBlip");
        }
        catch (JSDisconnectedException)
        {
            // Runtime shutting down
        }
        catch (JSException ex)
        {
            Console.WriteLine($"[MenuCard] Hover sound error: {ex.Message}");
        }
    }
}
